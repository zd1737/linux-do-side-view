{
  "manifest_version": 3,
  "name": "Linux.do SideView",
  "version": "1.1.5",
  "description": "为 linux.do 提供左右分栏的话题阅读体验，在右侧内嵌面板快速预览帖子内容。",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Linux.do SideView 设置"
  },
  "content_scripts": [
    {
      "matches": [
        "https://linux.do/*"
      ],
      "js": [
        "page-bridge.js"
      ],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://linux.do/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ]
}
